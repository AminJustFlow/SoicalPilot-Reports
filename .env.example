# IMAP
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=analytics@justflownh.com
IMAP_AUTH_METHOD=oauth2
IMAP_PASS=
IMPORT_START_MODE=manual

# OAuth2 (headless)
IMAP_OAUTH_ACCESS_TOKEN=
IMAP_OAUTH_TENANT_ID=<AZURE_TENANT_ID>
IMAP_OAUTH_CLIENT_ID=<AZURE_APP_CLIENT_ID>
IMAP_OAUTH_CLIENT_SECRET=<AZURE_APP_CLIENT_SECRET>
IMAP_OAUTH_REFRESH_TOKEN=<REAL_REFRESH_TOKEN_FOR_analytics@justflownh.com>
IMAP_OAUTH_SCOPE=https://outlook.office.com/IMAP.AccessAsUser.All offline_access
IMAP_OAUTH_TOKEN_ENDPOINT=

# Dropbox API mode for AWS/server deployments
UPLOAD_BACKEND=dropbox_api
DROPBOX_APP_KEY=<DROPBOX_APP_KEY>
DROPBOX_APP_SECRET=<DROPBOX_APP_SECRET>
DROPBOX_REFRESH_TOKEN=<DROPBOX_REFRESH_TOKEN>
DROPBOX_ACCESS_TOKEN=
DROPBOX_FOLDER_DEFAULT=/SocialPilot-Reports
DROPBOX_PATH_ROOT_MODE=auto
DROPBOX_PATH_ROOT_NAMESPACE_ID=
DROPBOX_FOLDER_PREFIX=/Just-Flow-Corporate

# Local mode only, for a laptop with Dropbox desktop sync installed
LOCAL_DROPBOX_ROOT=

# Runtime
HEALTH_HOST=0.0.0.0
HEALTH_PORT=3100
DB_PATH=./data/processed_messages.sqlite
DRY_RUN=false

# Admin UI auth (/routes and admin APIs)
ADMIN_USERNAME=<ADMIN_USERNAME>
ADMIN_PASSWORD=<ADMIN_PASSWORD>
